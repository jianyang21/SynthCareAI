DATABASE_URL=postgresql+asyncpg://hospital:hospital123@localhost:5432/hospital_db
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
OPENAI_API_KEY=not-needed-using-ollama

# --- LLM (Ollama primary, Gemini fallback) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=granite4:micro-h
GEMINI_API_KEY=your_gemini_api_key_here
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Qdrant ---
QDRANT_COLLECTION=hospital_ehr

# --- Hospital ---
# Comma-separated Telegram user IDs allowed to use the bot (empty = allow all)
ALLOWED_TELEGRAM_IDS=
HOSPITAL_TELEGRAM_ID=your_hospital_telegram_id_here
